# ═══════════════════════════════════════════════════════════════════════════════
# SBI EMS — Environment Variables Template
# DevSecOps Training | Secrets Management (Module 4)
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in real values in .env
#   3. .env is in .gitignore — it is NEVER committed to version control
#
# DevSecOps Principle:
#   "A secret in git is a secret forever."
#   Even if you delete the file later, git history preserves it.
#   Use pre-commit hooks (detect-secrets / gitleaks) to prevent accidents.
#
# In Production: Use HashiCorp Vault instead of a .env file.
#   vault kv put secret/ems jwt_secret=$(openssl rand -hex 32) db_password=...
# ═══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── JWT Secret ────────────────────────────────────────────────────────────────
# REQUIRED. Minimum 32 characters (256 bits).
# Generate a secure key: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_256_BIT_RANDOM_KEY_FROM_VAULT_OR_OPENSSL

# Token expiry in milliseconds (default: 3600000 = 1 hour)
JWT_EXPIRATION_MS=3600000

# ── Database (H2 in-memory for dev) ──────────────────────────────────────────
DB_URL=jdbc:h2:mem:emsdb;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
DB_DRIVER=org.h2.Driver
DB_USER=sa
DB_PASSWORD=

# ── Database (MySQL for production — uncomment and fill) ─────────────────────
# DB_URL=jdbc:mysql://localhost:3306/emsdb?useSSL=true&requireSSL=true
# DB_DRIVER=com.mysql.cj.jdbc.Driver
# DB_USER=ems_app_user
# DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_FROM_VAULT

# ── Spring Profile ────────────────────────────────────────────────────────────
# dev | prod
SPRING_PROFILES_ACTIVE=dev
